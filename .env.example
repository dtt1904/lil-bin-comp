# lil_Bin Company OS — Environment Variables
# Copy to .env and fill in values

# API key for lil_Bin orchestrator access (required)
INTERNAL_API_KEY="change-me-in-production"

# PostgreSQL connection (required)
DATABASE_URL="postgresql://lilbin:lilbin_secret@localhost:5432/lilbin_db?schema=public"

# Safety flag: keep "false" for real data environments.
# Set true only when you intentionally run destructive demo operations (db:seed, db:reset, /api/v1/system/seed).
ALLOW_DESTRUCTIVE_DB_OPS="false"
